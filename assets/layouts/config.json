      "type": "button",
      "keyCode": "Backspace",
      "anchor": [1, 0],
      "texture": "back_btn.png",
      "states": {
        "pressed": {
          "texture": "back_btn_focused.png"
        }
      },
      "position": [20, 20],
      "size": [80, 40],
      "style": {
        "fontSize": 40,
        "color": "white"
      }
    }
