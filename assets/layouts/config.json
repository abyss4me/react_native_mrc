        {
          "type": "text",
          "id": "name",
          "text": "PLAYER NAME",
          "anchor": [0.5, 0.5],
          "position": [0, 10],
          "style": {
            "textAlign": "center",
            "color": "white",
            "fontWeight": "bold",
            "fontSize": 8,
            "width": 844
