{
  "$schema": "./config.schema.json",
  "minClientVersion": "1.0.0",
  "settings": {
    "orientation": "auto",
    "keepAwake": true,
    "useSafeArea": false,
    "defaultCooldown": 50,
    "lockSafetyTimeout": 2500,
    "assetsBaseUrl": "https://h5.play.works/dev/pavlou/mrc_engine/assets/images/"
  },
  "theme": {
    "fonts": {
      "LibreFranklinBold": "https://h5.play.works/dev/pavlou/mrc_engine/assets/fonts/libre_franklin_bold.ttf"
    },
    "background": {
      "texture": "background.jpg"
    },
    "styles": {
      "controlButtonLabel": {
        "color": "white",
        "fontSize": 40,
        "fontWeight": "bold",
        "textShadowColor": "#000000",
        "textShadowOffset": {
          "width": 2,
          "height": 2
        },
        "textShadowRadius": 4
      },
      "testStyle": {
        "width": 640,
        "textAlign": "center",
        "color": "white",
        "fontSize": 30,
        "fontFamily": "LibreFranklinBold",
        "fontWeight": "bold",
        "textShadowColor": "rgba(0, 0, 0, 0.6)",
        "textShadowOffset": {
          "width": 0,
          "height": 3
        },
        "textShadowRadius": 4
      }
    }
  },
  "templates": {
    "AVATAR_GROUP": {
      "type": "container",
      "size": [60, 60],
      "layout": [
        {
          "type": "image",
          "id": "player_bg",
          "anchor": [0.5, 0.5],
