            "radius": 80,
            "haptic": "light",
            "hitbox": 10,
            "autoRepeat": true,
            "repeatInterval": 250,
            "texture": "control_btn.png",
            "states": {
              "pressed": {
                "texture": "control_btn_focused.png"
